{
  "name": "code-server-shared-terminals",
  "displayName": "Code Server Shared Terminals",
  "description": "在多个 code-server 浏览器窗口中发现并打开同一组持久终端任务。",
  "version": "0.1.2",
  "publisher": "aiwork",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/9904099/code-server-shared-terminals.git"
  },
  "engines": {
    "vscode": "^1.127.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/src/extension.js",
  "files": [
    "dist/src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test dist/test/*.test.js",
    "package": "vsce package --no-dependencies"
  },
  "contributes": {
    "commands": [
      {
        "command": "sharedTerminals.create",
        "title": "共享终端: 新建任务",
        "icon": "$(add)"
      },
      {
        "command": "sharedTerminals.open",
        "title": "共享终端: 打开任务"
      },
      {
        "command": "sharedTerminals.rename",
        "title": "共享终端: 重命名任务"
      },
      {
        "command": "sharedTerminals.delete",
        "title": "共享终端: 结束并删除任务",
        "icon": "$(trash)"
      },
      {
        "command": "sharedTerminals.refresh",
        "title": "共享终端: 刷新",
        "icon": "$(refresh)"
      },
      {
        "command": "sharedTerminals.openAll",
        "title": "共享终端: 打开全部任务"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "sharedTerminals.tasks",
          "name": "共享终端任务",
          "when": "workspaceFolderCount != 0"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "sharedTerminals.create",
          "when": "view == sharedTerminals.tasks",
          "group": "navigation@1"
        },
        {
          "command": "sharedTerminals.refresh",
          "when": "view == sharedTerminals.tasks",
          "group": "navigation@2"
        },
        {
          "command": "sharedTerminals.openAll",
          "when": "view == sharedTerminals.tasks",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "sharedTerminals.open",
          "when": "view == sharedTerminals.tasks",
          "group": "inline@1"
        },
        {
          "command": "sharedTerminals.rename",
          "when": "view == sharedTerminals.tasks",
          "group": "navigation@1"
        },
        {
          "command": "sharedTerminals.delete",
          "when": "view == sharedTerminals.tasks",
          "group": "navigation@2"
        }
      ]
    },
    "configuration": {
      "title": "共享终端",
      "properties": {
        "sharedTerminals.autoOpen": {
          "type": "boolean",
          "default": true,
          "description": "在当前浏览器工作台中自动打开服务器登记的共享终端任务。"
        },
        "sharedTerminals.registryPath": {
          "type": "string",
          "default": "/home/coder/.local/share/code-server/shared-terminals/tasks.json",
          "description": "服务器共享任务注册表路径。"
        },
        "sharedTerminals.defaultCwd": {
          "type": "string",
          "default": "/home/coder/aiwork",
          "description": "新建共享终端任务的默认工作目录。"
        }
      }
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.125.0",
    "@vscode/vsce": "^3.9.2",
    "typescript": "^5.9.0"
  }
}
